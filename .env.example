# Database
DATABASE_URL=postgresql+asyncpg://bps:bps@localhost:5432/brandprotection

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production

# Workers
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Screenshots
SCREENSHOT_DIR=/tmp/screenshots
SCREENSHOT_BASE_URL=http://localhost:8000/screenshots

# IP Reputation (optional — leave blank to skip)
ABUSEIPDB_API_KEY=

# Certstream
CERTSTREAM_URL=wss://certstream.calidog.io

# Logging
LOG_LEVEL=INFO
